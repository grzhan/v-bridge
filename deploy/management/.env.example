# Published ports on host
BACKEND_PORT=8000
FRONTEND_PORT=5173

# MySQL bootstrap
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=app_db
MYSQL_USER=app
MYSQL_PASSWORD=app_password

# Backend app config
APP_ENV=production
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_ORIGIN_REGEX=^https?://([a-zA-Z0-9.-]+|\[[0-9a-fA-F:]+\])(:[0-9]+)?$

# Guacamole config
GUAC_ENABLED=true
# If Guacamole runs on same host in Docker and maps host port 8081:
GUAC_BASE_URL=http://host.docker.internal:8081
GUAC_USERNAME=guacadmin
GUAC_PASSWORD=guacadmin
GUAC_DATA_SOURCE=postgresql

# Reclaimer
RECLAIM_INTERVAL_SECONDS=60
